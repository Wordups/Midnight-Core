# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL + the two API keys from the Supabase dashboard.
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Anthropic (Claude — metadata extraction, generation) ──────────────────────
ANTHROPIC_API_KEY=

# ── Voyage AI (embeddings for Bird Eye Review) ────────────────────────────────
VOYAGE_API_KEY=

# ── Google OAuth (Supabase-mediated) ──────────────────────────────────────────
# These live in the Supabase auth provider config; advertised here so the
# "Continue with Google" wiring can be reproduced in a new environment.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── App ───────────────────────────────────────────────────────────────────────
# Public base URL the frontend uses to redirect back into the app after OAuth.
FRONTEND_BASE_URL=
ENVIRONMENT=development
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ── Platform Admin ────────────────────────────────────────────────────────────
# Comma-separated emails that can access /api/admin/* and /admin.html.
# Set to your own email. Never expose this to end users.
PLATFORM_ADMIN_EMAILS=

# ── Optional ──────────────────────────────────────────────────────────────────
# Test login probe (scripts/dev/login_test.py) — used in dev only.
TEST_LOGIN_EMAIL=
TEST_LOGIN_PASSWORD=
# Bird Eye corpus tenant (scripts/ingest_bird_eye_corpus.py) — used in dev only.
TEST_TENANT_ID=
# Enterprise intake form.
FORMSPREE_ID=
